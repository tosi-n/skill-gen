# Browser Use (optional - for cloud features)
BROWSER_USE_API_KEY=

# LLM Provider (at least one required for research)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Skill Gen Configuration
SKILL_GEN_LLM=claude          # claude, gemini, openai
SKILL_GEN_MAX_DEPTH=3          # Max crawl depth
SKILL_GEN_MAX_PAGES=10         # Max pages per research session
SKILL_GEN_HEADED=false         # Show browser window
SKILL_GEN_SCREENSHOT_DIR=      # Save research screenshots
